{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "nodejs_18",
            "npm",
            "pkg-config",
            "cairo",
            "pango",
            "libjpeg",
            "giflib",
            "librsvg",
            "pixman",
            "libuuid",
            "python3",
            "make",
            "gcc"
          ]
        },
        "install": {
          "cmds": ["npm install --build-from-source"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
